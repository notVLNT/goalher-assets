#index .gh-hero-section {
  /* Layout */
  width: 100%;
  margin: 0 0 24px 0;
  padding: 32px 24px;
  box-sizing: border-box;
  
  /* Stile "Compact" che ti piaceva */
  background: linear-gradient(135deg, #5A189A 0%, #7B2FBE 50%, #9B72CF 100%);
  border-left: 4px solid #C77DFF;
  border-right: 4px solid #C77DFF;
  border-radius: 12px;
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 6px 20px rgba(90,24,154,0.3);
  
  /* Reset stili forum */
  clear: both;
  display: block;
}

/* Pattern decorativo */
#index .gh-hero-section::before {
  content: "";
  position: absolute;
  top: -20px;
  right: -20px;
  width: 60px;
  height: 60px;
  background: radial-gradient(circle, rgba(199,125,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
  animation: gh-pulse 4s ease-in-out infinite;
  pointer-events: none;
}

@keyframes gh-pulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.3); opacity: 0.3; }
}

#index .gh-hero-content {
  position: relative;
  z-index: 2;
  max-width: 600px;
  margin: 0 auto;
